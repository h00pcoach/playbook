# Database
DB_DSN=mysql:host=localhost;dbname=your_database_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Application secret (used for password-reset tokens — run: php -r "echo bin2hex(random_bytes(32));")
APP_SECRET=replace_with_a_long_random_string

# Braintree — Sandbox
BT_MERCH_ID_SAND=
BT_PUB_KEY_SAND=
BT_PRIV_KEY_SAND=

# Braintree — Production
BT_MERCH_ID_PROD=
BT_PUB_KEY_PROD=
BT_PRIV_KEY_PROD=
